# =============================================================================
# REQUIRED — fill all of these before running specflow-init.sh
# =============================================================================

# GITHUB_TOKEN
#   What:  GitHub Personal Access Token used to create and manage disposable
#          workspace repositories where agents commit generated code.
#   How:   Generate a classic PAT with `repo` + `workflow` scopes:
#          https://github.com/settings/tokens/new?scopes=repo,workflow
GITHUB_TOKEN=

# P10Y_API_KEY
#   What:  API key for Compass by P10Y — a code-complexity scoring service.
#          SpecFlow uses it to measure generated code complexity and compare
#          implementation variants across parallel workspaces.
#   How:   1. Create a Compass account at https://compass.p10y.com
#          2. Connect your GitHub org (Settings > Integrations > GitHub).
#          3. Generate an API token (Settings > API Tokens).
#   Docs:  Setup guide: https://github.com/griddynamics/specflow/blob/main/docs/quickstart-compass.md
#          Compass portal: https://compass.p10y.com
P10Y_API_KEY=

# LLM provider — set ONE of the two keys below; leave the other blank.
# The provider is derived from whichever single key you set (Anthropic key
# only → Anthropic; OpenRouter key → OpenRouter). If both are set, OpenRouter is
# used by default. If neither is set, the backend refuses to start.
#
# OPENROUTER_API_KEY (default provider)
#   What:  API key for OpenRouter, an LLM provider aggregator that routes
#          requests to Claude and other models. This is the default provider.
#   How:   Create an account and generate a key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
#
# ANTHROPIC_API_KEY (alternative — direct Anthropic access)
#   What:  API key for Anthropic's Claude API. Use this instead of OpenRouter
#          if you prefer direct access or your org requires it.
#   How:   Generate a key: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=

# =============================================================================
# LOCAL — pre-filled with sensible quickstart defaults; change if needed
# =============================================================================

# AUTH_MODE
#   What:  Controls how the backend authenticates inbound requests.
#          "local" = single-user mode, no API key header required.
#          "api_key" = multi-user/production mode, requires a valid API key.
#   How:   Leave as "local" for quickstart. Only change for production.
AUTH_MODE=local

# DATABASE_TYPE
#   What:  Which persistence backend to use for state and session data.
#          "emulator" = bundled Firestore emulator container (no GCP needed).
#          "firestore" = real GCP Firestore (production).
#          "memory" = in-memory only (unit tests).
#   How:   Leave as "emulator" for quickstart. No GCP credentials required.
DATABASE_TYPE=emulator

# FIRESTORE_EMULATOR_HOST
#   What:  Network address of the Firestore emulator. Only used when
#          DATABASE_TYPE=emulator.
#   How:   Leave as "localhost:8080". Host-side scripts (init_firestore.py)
#          connect here. Inside the backend container, docker-compose
#          automatically injects "firestore-emulator:8080".
FIRESTORE_EMULATOR_HOST=localhost:8080

# GCP_PROJECT_ID
#   What:  GCP project identifier passed to the Firestore client.
#          For the emulator this is an arbitrary string (not validated).
#          For production Firestore, use your real GCP project ID.
#   How:   Leave as "local-dev" for quickstart.
GCP_PROJECT_ID=local-dev

# FIRESTORE_DATABASE_NAME
#   What:  Logical database name within the Firestore project.
#   How:   Leave as "specflow" for quickstart.
FIRESTORE_DATABASE_NAME=specflow

# WORKSPACE_BASE_PATH / AGENT_LOGS_BASE_PATH
#   What:  Container-internal mount points for workspace code and agent logs.
#          Host-side bind mounts are ./workspaces/ and ./agent_logs/ respectively
#          (configured in docker-compose.yml).
#   How:   Keep as-is unless you change docker-compose bind-mounts.
WORKSPACE_BASE_PATH=/workspaces
AGENT_LOGS_BASE_PATH=/agent_logs

# FIRESTORE_EXPORT_INTERVAL_SECONDS
#   What:  How often (in seconds) the emulator sidecar exports Firestore state
#          to ./workspaces/firestore_emulator/ for crash durability. On restart
#          the emulator restores from the last export automatically.
#   How:   Leave as 25. Reset all exported data with: ./specflow-init.sh --reset-local-db
FIRESTORE_EXPORT_INTERVAL_SECONDS=25

# USER_EMAIL / GIT_USER_EMAIL
#   What:  Your email identity used for MCP config, notification emails, and
#          git commit authorship on workspaces.
#   How:   Leave both blank to auto-derive from `git config user.email`.
#          Resolution chain: USER_EMAIL -> GIT_USER_EMAIL -> git config user.email.
#          Set GIT_USER_EMAIL explicitly only if git config is empty.
USER_EMAIL=
GIT_USER_EMAIL=

# LOCAL_USER_NAME
#   What:  Display name stored in the local auth identity record.
#   How:   Optional. Leave blank or uncomment and set your name.
# LOCAL_USER_NAME=

# GITHUB_ORG
#   What:  GitHub organisation where workspace repos are created
#          (e.g. "my-org" creates repos like my-org/specflow-workspace-ws-1).
#   How:   Leave blank to use GIT_USER_NAME (your GitHub login).
#          Set explicitly if your git user.name is not your GitHub account
#          or organization name.
GITHUB_ORG=

# GIT_COMMITTER_USER_EMAIL
#   What:  Email for system-level git commits (archive, workspace reset).
#          This is NOT your personal commit email — it identifies automated
#          SpecFlow operations in git history.
#   How:   Leave as default unless you want a different system identity.
GIT_COMMITTER_USER_EMAIL=specflow@system.local

# GITHUB_TEAM_SLUG
#   What:  GitHub team that gets Write access to workspace repos.
#          Used for team-scoped PATs or fine-grained org permissions.
#   How:   Optional. Uncomment and set if your PAT is team-scoped.
# GITHUB_TEAM_SLUG=

# WORKSPACE_REPO_PREFIX
#   What:  Naming prefix for auto-created workspace repositories.
#          Repos are created as {GITHUB_ORG}/{prefix}-ws-1, {prefix}-ws-2, etc.
#   How:   Change if you want a different naming convention for workspace repos.
WORKSPACE_REPO_PREFIX=specflow-workspace

# =============================================================================
# OPTIONAL — leave blank to disable; safe to omit entirely
# =============================================================================

# --- PostHog (product analytics) ---
# POSTHOG_ENABLED / POSTHOG_API_KEY
#   What:  PostHog tracks product usage events (generation counts, durations).
#          Disabled by default for quickstart privacy.
#   How:   Set POSTHOG_ENABLED=true and provide your API key to enable.
#   Docs:  https://posthog.com
POSTHOG_ENABLED=false
# POSTHOG_API_KEY=

# --- Langfuse (LLM observability) ---
# LANGFUSE_PUBLIC_KEY / LANGFUSE_SECRET_KEY / LANGFUSE_BASE_URL
#   What:  Langfuse traces all LLM API calls — logs prompts, completions,
#          token counts, latencies, and costs. All three vars must be set
#          to enable; leaving any blank disables tracing entirely.
#   How:   Create a Langfuse project and copy the keys from project settings.
#   Docs:  https://langfuse.com
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_BASE_URL=

# --- Slack (generation notifications) ---
# SLACK_WEBHOOK_URL
#   What:  Incoming webhook URL for Slack notifications. SpecFlow posts a
#          summary message when a generation run completes or fails.
#   How:   Create an incoming webhook in your Slack workspace.
#   Docs:  https://api.slack.com/messaging/webhooks
# SLACK_WEBHOOK_URL=

# --- Email (generation notifications) ---
# NOTIFY_EMAIL_USERNAME / NOTIFY_EMAIL_PASSWORD
#   What:  SMTP credentials for email notifications on generation completion.
#          Both must be set to enable email notifications.
#   How:   Use your SMTP service credentials (e.g. Gmail app password, SendGrid).
# NOTIFY_EMAIL_USERNAME=
# NOTIFY_EMAIL_PASSWORD=

# --- Figma (design context for agents) ---
# FIGMA_ACCESS_TOKEN
#   What:  Personal access token for the Figma API. When enabled, the Figma MCP
#          server fetches design files to give code-generation agents visual
#          context from your designs.
#   How:   1. Generate a token: https://www.figma.com/developers/api#access-tokens
#          2. Add "figma" to MCP_SERVERS_ENABLED below.
# FIGMA_ACCESS_TOKEN=

# --- Rosetta / KnowledgeBase (project knowledge for codegen agents) ---
#   Two modes — choose one:
#
#   Mode 1: Bundled plugin (default, open-source quickstart)
#     Generic KB, runs locally, no external credentials needed.
#     Leave ROSETTA_MCP_ENABLED=false and keep the default ROSETTA_PLUGIN_PATH.
#
#   Mode 2: Live MCP (project-tailored KB, Grid Dynamics managed)
#     Connects to the Grid Dynamics IMS service for project-specific knowledge.
#     Set ROSETTA_MCP_ENABLED=true and fill in the credentials below.
#     Live MCP takes precedence when both are configured.
#
#   Docs:  https://github.com/griddynamics/rosetta
#
# ROSETTA_MCP_ENABLED
#   What:  Toggle between bundled plugin (false) and live IMS-MCP server (true).
ROSETTA_MCP_ENABLED=false
#
# ROSETTA_PLUGIN_PATH
#   What:  Path to the generic KB plugin baked into the Docker image.
#   How:   Keep as-is. Only change if you mount a custom plugin.
ROSETTA_PLUGIN_PATH=/opt/rosetta-plugin
#
# ROSETTA_MARKETPLACE_REF
#   What:  Git tag/branch/SHA of the public griddynamics/rosetta marketplace to bake into
#          the image at BUILD time (build arg, not a runtime setting). Pins the plugin version.
#   How:   Bump to a newer tag and rebuild the backend image to upgrade the bundled KB plugin.
ROSETTA_MARKETPLACE_REF=v2.0.55
#
# ROSETTA_API_KEY / ROSETTA_USER_EMAIL / ROSETTA_SERVER_URL
#   What:  Credentials for the live IMS-MCP Rosetta service.
#          Only needed when ROSETTA_MCP_ENABLED=true.
#   How:   Obtain from your Grid Dynamics IMS admin.
# ROSETTA_API_KEY=
# ROSETTA_USER_EMAIL=
# ROSETTA_SERVER_URL=https://ims.evergreen.gcp.griddynamics.net/

# --- Agent MCP servers ---
# MCP_SERVERS_ENABLED
#   What:  Comma-separated list of optional MCP servers available to codegen
#          agents. Per-phase overrides are possible via IMPLEMENTATION_PLAN.md.
#          Valid values: "playwright" (browser automation), "figma" (design context).
#   How:   Default enables Playwright. Add "figma" if you set FIGMA_ACCESS_TOKEN.
#          Example: playwright,figma
MCP_SERVERS_ENABLED=playwright

# WORKSPACE_EXCLUDE_PATTERNS
#   What:  Extra file paths excluded when syncing code into parallel workspaces.
#          These are added to the built-in exclusions (node_modules, .git, venvs,
#          build output, etc.) — they do not replace them.
#   How:   Python list literal. Example: ['.log', '.data', 'large_fixtures/']
#          Leave blank for defaults only.
WORKSPACE_EXCLUDE_PATTERNS=

# =============================================================================
# AUTO-MANAGED — populated by specflow-init.sh; do not set manually
# =============================================================================

# GIT_USER_NAME
#   What:  Your GitHub login — the owner/namespace for workspace repos and the
#          git committer identity for workspace-pool operations.
#   How:   Auto-resolved from your GitHub account (GET /user) on first run using
#          GITHUB_TOKEN. Set it explicitly only if that resolution is impossible.
GIT_USER_NAME=

# TOKEN_ENCRYPTION_KEY
#   What:  Fernet symmetric key for encrypting GitHub PATs at rest in Firestore.
#          Auto-generated on first run. Back up this key — token decryption
#          fails without it (you would need to re-enter GITHUB_TOKEN).
#   How:   Auto-generated by specflow-init.sh. Do not edit.
TOKEN_ENCRYPTION_KEY=

# P10Y_ORGANISATION_ID
#   What:  Numeric organisation ID from Compass/P10Y, used to scope API calls.
#   How:   Auto-resolved from P10Y_API_KEY via the Compass /api/user/self endpoint.
P10Y_ORGANISATION_ID=
